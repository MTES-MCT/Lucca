{#-- Translation domain --#}
{% trans_default_domain 'DepartmentBundle' %}

{{ form_start(form) }}
{{ form_errors(form) }}
<div class="row">
    <div class="col-12 col-xl-6">
        <div class="card card-default">
            <div class="card-header">
                {% if department is defined %}
                    {{ 'title.edit'|trans({}, 'ThemeStreamDashboardUiKit') }} - <b>{{ department.name }}</b>
                {% else %}
                    {{ 'title.new'|trans({}, 'ThemeStreamDashboardUiKit') }} {{ entity_trans }}
                {% endif %}
            </div>

            <div class="card-wrapper">
                <div class="card-body">
                    <div class="col-12">
                        {# Display AutoImport toggle first if exists #}
                        {% if form.autoImport is defined %}
                            <div class="form-group mb-4 p-3 bg-light border rounded">
                                {{ form_row(form.autoImport) }}
                                <small class="text-muted">{{ 'help.autoImportApiGouvDescription'|trans }}</small>
                            </div>
                        {% endif %}

                        {{ form_row(form.code) }}

                        {# Wrap manual fields in a specific div for JS #}
                        <div id="manual-fields-container">
                            {{ form_row(form.name) }}

                            {% if form.towns is defined %}
                                <div class="form-group row csv-upload-field">
                                    {{ form_label(form.towns) }}
                                    <div class="col-sm-10">
                                        {{ form_widget(form.towns) }}
                                        {{ form_help(form.towns)|nl2br }}
                                        <div class="mt-2">
                                            <a href="{{ asset('examples/import_commune_example.csv') }}" download>
                                                <button type="button" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-download"></i> {{ 'label.downloadFileExample' | trans }}
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}

                        </div>
                        {{ form_row(form.comment) }}

                        {% if form.showInHomePage is defined %}
                            {{ form_row(form.showInHomePage) }}
                        {% endif %}
                    </div>

                    <div class="col-md-12 col-12 pb-3 px-0">
                        {% block theme_embed_buttons_department %}{% endblock %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{ form_rest(form) }}
{{ form_end(form) }}
