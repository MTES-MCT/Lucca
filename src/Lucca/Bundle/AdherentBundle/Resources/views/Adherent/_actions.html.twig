<div class="btn-group">
    {#-- Show Button --#}
    <a href="{{ path('lucca_adherent_show', { 'id': id }) }}"
       class="btn btn-primary btn-sm"
       title="{{ 'link.adherent.show'|trans({}, 'AdherentBundle') }}">
        <i class="fa fa-eye"></i>
    </a>

    {#-- Edit Button --#}
    <a href="{{ path('lucca_adherent_edit', { 'id': id }) }}"
       class="btn btn-warning btn-sm"
       title="{{ 'link.adherent.edit'|trans({}, 'AdherentBundle') }}">
        <i class="fas fa-pencil-alt"></i>
    </a>

    {#-- Toggle Enable/Disable Button --#}
    {% if enabled %}
        <a href="{{ path('lucca_adherent_disable', { 'id': id }) }}"
           class="btn btn-info btn-sm"
           title="{{ 'link.adherent.disable'|trans({}, 'AdherentBundle') }}">
            <i class="fa fa-toggle-on"></i>
        </a>
    {% else %}
        <a href="{{ path('lucca_adherent_enable', { 'id': id }) }}"
           class="btn btn-danger btn-sm"
           title="{{ 'link.adherent.enable'|trans({}, 'AdherentBundle') }}">
            <i class="fa fa-toggle-off"></i>
        </a>
    {% endif %}
</div>
